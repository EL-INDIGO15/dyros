-- ==================== GUARDAR ESTADO ORIGINAL PARA RESTAURAR ANTI-LAG ====================
local originalLighting = {
    Ambient = Lighting.Ambient,
    OutdoorAmbient = Lighting.OutdoorAmbient,
    Brightness = Lighting.Brightness,
    ClockTime = Lighting.ClockTime,
    GlobalShadows = Lighting.GlobalShadows,
    FogEnd = Lighting.FogEnd,
    FogStart = Lighting.FogStart,
    FogColor = Lighting.FogColor,
}
local modifiedObjects = {}

local function applyExtremeAntiLag()
    modifiedObjects = {}
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") or v:IsA("Trail") then
            if v.Enabled then
                table.insert(modifiedObjects, v)
                v.Enabled = false
            end
        elseif v:IsA("Decal") or v:IsA("Texture") then
            if v.Transparency < 1 then
                table.insert(modifiedObjects, v)
                v.Transparency = 1
            end
        elseif v:IsA("BasePart") and not v:IsA("MeshPart") then
            if v.Material ~= Enum.Material.SmoothPlastic or v.Reflectance > 0 then
                table.insert(modifiedObjects, v)
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
            end
        end
    end

    Lighting.Ambient = Color3.fromRGB(0,0,0)
    Lighting.OutdoorAmbient = Color3.fromRGB(0,0,0)
    Lighting.Brightness = 0
    Lighting.ClockTime = 0
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9
    Lighting.FogColor = Color3.fromRGB(0,0,0)

    settings().Rendering.QualityLevel = 1
    StarterGui:SetCore("SendNotification", {Title = "ANTI-LAG", Text = "Mapa negro activado", Duration = 4})
end

local function restoreNormal()
    for prop, value in pairs(originalLighting) do
        Lighting[prop] = value
    end

    for _, obj in pairs(modifiedObjects) do
        if obj then
            if obj:IsA("ParticleEmitter") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") or obj:IsA("Trail") then
                obj.Enabled = true
            elseif obj:IsA("Decal") or obj:IsA("Texture") then
                obj.Transparency = 0
            elseif obj:IsA("BasePart") then
                obj.Material = Enum.Material.Plastic
                obj.Reflectance = 0
            end
        end
    end
    table.clear(modifiedObjects)

    settings().Rendering.QualityLevel = 10
    StarterGui:SetCore("SendNotification", {Title = "ANTI-LAG", Text = "Todo restaurado a normalidad", Duration = 4})
end

-- ==================== AUTO TAMAÑO 0.01 (método SETTINGS que te gusta) ====================
local function applyTinySize(char)
    task.wait(2) -- esperamos a que cargue completamente

    -- Método manual de respaldo
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Size = part.Size * 0.01
        end
    end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then root.Size = Vector3.new(0.01, 0.01, 0.01) end

    -- Método SETTINGS (el que te sirve - se auto-cambia al abrir Settings)
    task.spawn(function()
        while char.Parent do
            task.wait(0.8)
            pcall(function()
                for _, gui in pairs(LocalPlayer:WaitForChild("PlayerGui"):GetDescendants()) do
                    if gui:IsA("TextBox") or gui:IsA("TextLabel") then
                        if (gui.Text:find("Size") or gui.Name:lower():find("size")) and gui.Parent then
                            local textbox = gui.Parent:FindFirstChildWhichIsA("TextBox") or gui
                            if textbox then
                                textbox.Text = "0.01"
                                -- Simula el cambio (como si lo cambiaras tú manualmente)
                                if textbox.FocusLost then
                                    textbox.FocusLost:Fire()
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)
end

if LocalPlayer.Character then applyTinySize(LocalPlayer.Character) end
