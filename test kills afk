-- ==================== EQUIP PUNCH + KILL HOP MÁS RÁPIDO ====================
local function EquipPunch()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        local tool = backpack:FindFirstChild("Punch")
        if tool and LocalPlayer.Character and not LocalPlayer.Character:FindFirstChild("Punch") then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum:EquipTool(tool) end
        end
    end
end

local function killHopLoop()
    while AutoKillHopEnabled do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                table.insert(targets, plr)
            end
        end

        for _, target in ipairs(targets) do
            if not AutoKillHopEnabled then break end
            if not target.Character or not target.Character:FindFirstChild("Humanoid") then continue end

            local targetHRP = target.Character.HumanoidRootPart
            local targetHum = target.Character.Humanoid
            local killed = false

            local deathConnection = targetHum.Died:Connect(function() killed = true end)

            local startTime = tick()
            while tick() - startTime < 0.25 and not killed and AutoKillHopEnabled do
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local myHRP = LocalPlayer.Character.HumanoidRootPart
                    -- TP un poco más abajo de cada jugador (cerca de los pies)
                    myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 1, 0)

                    EquipPunch()
                    local punch = LocalPlayer.Character:FindFirstChild("Punch")
                    if punch then
                        punch:Activate()
                        task.wait(0.01)
                    end
                end
                task.wait(0.01)
            end

            deathConnection:Disconnect()
            task.wait(0.01)
        end
        task.wait(0.03)
    end
end

-- ==================== HOP LOGIC (igual) ====================
local function findServer()
    local cursor = nil
    repeat
        local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
        if cursor then url = url .. "&cursor=" .. cursor end
        local success, response = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
        if success and response and response.data then
            for _, server in ipairs(response.data) do
                if server.playing > 6 and server.id ~= game.JobId then
                    return server.id
                end
            end
            cursor = response.nextPageCursor
        else break end
    until not cursor
    return nil
end

local function hopToServer()
    local serverId = findServer()
    if serverId then
        TeleportService:TeleportToPlaceInstance(placeId, serverId, LocalPlayer)
    else
        task.delay(3, hopToServer)
    end
end

