local colores = {
    Color3.fromRGB(220, 20, 60),   -- Rojo original (Crimson)
    Color3.fromRGB(255, 102, 102), -- Rojo claro
    Color3.fromRGB(255, 0, 0),     -- Rojo fuerte / puro
