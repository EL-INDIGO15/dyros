local AutoFarmToggle = Tab:AddToggle("AutoFarm", { 
    Title = "Auto Farm", 
    Default = false 
})

AutoFarmToggle:OnChanged(function()
    local Value = Options.AutoFarm.Value
    if Value then
        stopAll()
        AutoFarmEnabled = true
        if rebirths.Value < 10 then
            RunScriptBelow10()
        else
            RunScriptAboveOrEqual10()
        end
    else
        stopAll()
    end
end)

