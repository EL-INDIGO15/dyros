        Vector3.new(2743.69, 11.66, 258.49)
    }

    local folder = workspace:WaitForChild("MachinesFolder")
    local remote = ReplicatedStorage.RemotesEvent.MachineActiveEvent

    local prompts = getPrompts(folder, positions)

    table.insert(farmThreads, task.spawn(function()
        while AutoFarmEnabled do
            local p = prompts[rng:NextInteger(1, #prompts)]
