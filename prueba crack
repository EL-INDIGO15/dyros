local activeThreads = {}
local targetBags = {}

local function stopFarm(bagName)
    if activeThreads[bagName] then
        activeThreads[bagName]:Disconnect()
        activeThreads[bagName] = nil
    end
    if targetBags[bagName] and targetBags[bagName]:IsA("BasePart") and targetBags[bagName].Parent then
        bagPositions[bagName] = targetBags[bagName].Position
        targetBags[bagName].Anchored = true
    end
    targetBags[bagName] = nil
end

local function gettool()
    for i, v in pairs(player.Backpack:GetChildren()) do
        if v.Name == "Punch" and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid:EquipTool(v)
        end
    end
    player.muscleEvent:FireServer("punch", "leftHand")
    player.muscleEvent:FireServer("punch", "rightHand")
end

local function findBagByPos(bagName, searchPos)
    local closest = nil
    local minDist = 100

    local bagsFolder = workspace:FindFirstChild("punching bags")
    if not bagsFolder then return nil end

    for _, v in pairs(bagsFolder:GetChildren()) do
        if v.Name == "PunchingBag" and v:IsA("BasePart") then
            local dist = (v.Position - searchPos).Magnitude
            if dist < minDist then
                minDist = dist
                closest = v
            end
        end
    end
    return closest
end

local function farmBag(bagName, bool)
    if not bool then
        stopFarm(bagName)
        return
    end

    stopFarm(bagName)

    local searchPos = bagPositions[bagName]
    targetBags[bagName] = findBagByPos(bagName, searchPos)
    if not targetBags[bagName] then
        warn(bagName.. " no encontrado cerca de ".. tostring(searchPos))
        return
    end

    targetBags[bagName].Anchored = false
    targetBags[bagName].CanCollide = false
    targetBags[bagName].Transparency = 1

    activeThreads[bagName] = RunService.Heartbeat:Connect(function()
        if not targetBags[bagName] or not targetBags[bagName].Parent then
            stopFarm(bagName)
            return
        end

        local char = player.Character
        if not char then return end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        local leftHand = char:FindFirstChild("LeftHand")
        local rightHand = char:FindFirstChild("RightHand")
        if not hrp or not leftHand or not rightHand then return end

        targetBags[bagName].CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
        targetBags[bagName].Velocity = Vector3.zero
        targetBags[bagName].RotVelocity = Vector3.zero

        firetouchinterest(targetBags[bagName], rightHand, 0)
        firetouchinterest(targetBags[bagName], rightHand, 1)
        firetouchinterest(targetBags[bagName], leftHand, 0)
        firetouchinterest(targetBags[bagName], leftHand, 1)

        gettool()
    end)
end

