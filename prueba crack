            local total = 0
            for _, c in pairs(petCount) do total = total + c end
            if total > 0 then
                addStat("━━━━━━━━ PETS ("..total..") ━━━━━━━━")
                for name, count in pairs(petCount) do
                    addStat("🐾 "..name..(count > 1 and " x"..count or ""))
                end
            end
        end
    end)
end

