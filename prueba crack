local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")

local AntiLagEnabled = false
local OriginalSettings = {}
local OriginalParts = {}

-- Guardar settings originales
local function SaveOriginalSettings()
    OriginalSettings.Brightness = Lighting.Brightness
    OriginalSettings.GlobalShadows = Lighting.GlobalShadows
    OriginalSettings.FogEnd = Lighting.FogEnd
    OriginalSettings.Ambient = Lighting.Ambient
    OriginalSettings.OutdoorAmbient = Lighting.OutdoorAmbient
    OriginalSettings.Technology = Lighting.Technology
end

-- Activar AntiLag
local function EnableAntiLag()
    if AntiLagEnabled then return end
    AntiLagEnabled = true

    SaveOriginalSettings()

    -- 1. Lighting al mínimo
    Lighting.Brightness = 0
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Ambient = Color3.new(0, 0, 0)
    Lighting.OutdoorAmbient = Color3.new(0, 0, 0)
    Lighting.Technology = Enum.Technology.Compatibility

    -- 2. Quitar efectos de luz
    for _, v in pairs(Lighting:GetDescendants()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
            v.Enabled = false
        end
    end

    -- 3. Poner todo el mapa negro
    for _, part in pairs(Workspace:GetDescendants()) do
        if part:IsA("BasePart") and part.Transparency < 1 then
            OriginalParts[part] = {
                Color = part.Color,
                Material = part.Material,
                Reflectance = part.Reflectance
            }
            part.Color = Color3.new(0, 0, 0)
            part.Material = Enum.Material.SmoothPlastic
            part.Reflectance = 0
        elseif part:IsA("Decal") or part:IsA("Texture") then
            OriginalParts[part] = {Transparency = part.Transparency}
            part.Transparency = 1
        elseif part:IsA("ParticleEmitter") or part:IsA("Fire") or part:IsA("Smoke") or part:IsA("Sparkles") then
            OriginalParts[part] = {Enabled = part.Enabled}
            part.Enabled = false
        end
    end
end

-- Desactivar AntiLag
local function DisableAntiLag()
    if not AntiLagEnabled then return end
    AntiLagEnabled = false

    -- Restaurar Lighting
    for setting, value in pairs(OriginalSettings) do
        Lighting[setting] = value
    end

    for _, v in pairs(Lighting:GetDescendants()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
            v.Enabled = true
        end
    end

    -- Restaurar partes
    for part, props in pairs(OriginalParts) do
        if part and part.Parent then
            for prop, val in pairs(props) do
                part[prop] = val
            end
        end
    end

    table.clear(OriginalParts)
end

