function Folder:AddKeybind(text, defaultKey, callback)

	defaultKey = defaultKey or Enum.KeyCode.RightControl
	local currentKey = defaultKey

	local Frame = Instance.new("Frame")
	Frame.Size = UDim2.new(1,0,0,35)
	Frame.BackgroundColor3 = self.Config.MainColor
	Frame.Parent = self.Container

	if self.Config.CornerRadius > 0 then
		Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,6)
	end

	local Button = Instance.new("TextButton")
	Button.Size = UDim2.new(1,0,1,0)
	Button.BackgroundTransparency = 1
	Button.Text = text.." : "..currentKey.Name
	Button.TextColor3 = self.Config.TextColor
	Button.Font = Enum.Font.Gotham
	Button.TextSize = 14
	Button.Parent = Frame

	local waiting = false
	local UIS = game:GetService("UserInputService")

	Button.MouseButton1Click:Connect(function()
		Button.Text = text.." : ..."
		waiting = true
	end)

	UIS.InputBegan:Connect(function(input, gpe)
		if gpe then return end

		if waiting then
			if input.KeyCode ~= Enum.KeyCode.Unknown then
				currentKey = input.KeyCode
				Button.Text = text.." : "..currentKey.Name
				waiting = false
			end
		else
			if input.KeyCode == currentKey then
				if callback then
					callback()
				end
			end
		end
	end)

	return {
		Get = function()
			return currentKey
		end
	}
end


