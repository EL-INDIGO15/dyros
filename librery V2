--// ==============================
--// CREATE WINDOW
--// ==============================

function HadesUI:CreateWindow(title)

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "HadesUI"
	ScreenGui.Parent = Player:WaitForChild("PlayerGui")

	local Main = Instance.new("Frame")
	Main.Size = UDim2.new(0,550,0,400)
	Main.Position = UDim2.new(0.5,-275,0.5,-200)
	Main.BackgroundColor3 = self.Config.MainColor
	Main.Parent = ScreenGui

	if self.Config.CornerRadius > 0 then
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0,self.Config.CornerRadius)
		corner.Parent = Main
	end

	if self.Config.BackgroundImage then
		local BG = Instance.new("ImageLabel")
		BG.Size = UDim2.new(1,0,1,0)
		BG.BackgroundTransparency = 1
		BG.Image = self.Config.BackgroundImage
		BG.Parent = Main
	end

	--// TITLE
	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1,0,0,40)
	Title.BackgroundTransparency = 1
	Title.Text = title
	Title.TextColor3 = self.Config.TextColor
	Title.Font = Enum.Font.GothamBold
	Title.TextSize = 20
	Title.Parent = Main

	--// MINIMIZE BUTTON
	local MinBtn = Instance.new("TextButton")
	MinBtn.Size = UDim2.new(0,80,0,28)
	MinBtn.Position = UDim2.new(1,-90,0,6)
	MinBtn.Text = "Hades"
	MinBtn.BackgroundColor3 = self.Config.AccentColor
	MinBtn.TextColor3 = Color3.new(1,1,1)
	MinBtn.Font = Enum.Font.GothamBold
	MinBtn.TextSize = 14
	MinBtn.Parent = Main

	if self.Config.CornerRadius > 0 then
		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0,6)
		c.Parent = MinBtn
	end

	--// HOLDER
	local Holder = Instance.new("Frame")
	Holder.Size = UDim2.new(1,-20,1,-60)
	Holder.Position = UDim2.new(0,10,0,50)
	Holder.BackgroundTransparency = 1
	Holder.Parent = Main

	local UIList = Instance.new("UIListLayout")
	UIList.Padding = UDim.new(0,8)
	UIList.Parent = Holder

	--// DRAG SYSTEM
	local dragging, dragInput, dragStart, startPos

	Main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = Main.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			Main.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)

	--// MINIMIZE LOGIC
	local minimized = false

	MinBtn.MouseButton1Click:Connect(function()
		minimized = not minimized

		if minimized then
			TweenService:Create(Main, TweenInfo.new(0.25), {
				Size = UDim2.new(0,550,0,45)
			}):Play()
		else
			TweenService:Create(Main, TweenInfo.new(0.25), {
				Size = UDim2.new(0,550,0,400)
			}):Play()
		end
	end)

	local Window = {}
	Window.Holder = Holder
	Window.Config = self.Config

	return Window
end

--// ==============================
--// FOLDER SYSTEM
--// ==============================

function Window:AddFolder(name)

	local Folder = {}
	Folder.Config = self.Config

	--// HEADER
	local Header = Instance.new("TextButton")
	Header.Size = UDim2.new(1,0,0,35)
	Header.BackgroundColor3 = self.Config.AccentColor
	Header.Text = "▼ "..name
	Header.TextColor3 = Color3.new(1,1,1)
	Header.Font = Enum.Font.GothamBold
	Header.TextSize = 14
	Header.Parent = self.Holder

	if self.Config.CornerRadius > 0 then
		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0,6)
		c.Parent = Header
	end

	--// CONTAINER
	local Container = Instance.new("Frame")
	Container.Size = UDim2.new(1,0,0,0)
	Container.BackgroundTransparency = 1
	Container.ClipsDescendants = true
	Container.Parent = self.Holder

	local UIList = Instance.new("UIListLayout")
	UIList.Padding = UDim.new(0,6)
	UIList.Parent = Container

	local opened = false

	Header.MouseButton1Click:Connect(function()
		opened = not opened
		Header.Text = (opened and "▲ " or "▼ ")..name

		if opened then
			Container:TweenSize(
				UDim2.new(1,0,0,UIList.AbsoluteContentSize.Y + 5),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.25,
				true
			)
		else
			Container:TweenSize(
				UDim2.new(1,0,0,0),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.25,
				true
			)
		end
	end)

	UIList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		if opened then
			Container.Size = UDim2.new(1,0,0,UIList.AbsoluteContentSize.Y + 5)
		end
	end)

	Folder.Container = Container

	--// ==============================
	--// BUTTON
	--// ==============================

	function Folder:AddButton(text, callback)

		local Btn = Instance.new("TextButton")
		Btn.Size = UDim2.new(1,0,0,30)
		Btn.BackgroundColor3 = self.Config.MainColor
		Btn.Text = text
		Btn.TextColor3 = self.Config.TextColor
		Btn.Font = Enum.Font.Gotham
		Btn.TextSize = 14
		Btn.Parent = Container

		if self.Config.CornerRadius > 0 then
			local c = Instance.new("UICorner")
			c.CornerRadius = UDim.new(0,6)
			c.Parent = Btn
		end

		Btn.MouseButton1Click:Connect(function()

			Btn:TweenSize(UDim2.new(0.97,0,0,28),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.1,true)

			task.wait(0.1)

			Btn:TweenSize(UDim2.new(1,0,0,30),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.1,true)

			if callback then
				callback()
			end
		end)

	end

	--// ==============================
	--// SWITCH
	--// ==============================

	function Folder:AddSwitch(text, callback)

		local toggled = false

		local Frame = Instance.new("Frame")
		Frame.Size = UDim2.new(1,0,0,30)
		Frame.BackgroundColor3 = self.Config.MainColor
		Frame.Parent = Container

		if self.Config.CornerRadius > 0 then
			local c = Instance.new("UICorner")
			c.CornerRadius = UDim.new(0,6)
			c.Parent = Frame
		end

		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(0.7,0,1,0)
		Label.BackgroundTransparency = 1
		Label.Text = text
		Label.TextColor3 = self.Config.TextColor
		Label.Font = Enum.Font.Gotham
		Label.TextSize = 14
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Parent = Frame

		local ToggleBG = Instance.new("Frame")
		ToggleBG.Size = UDim2.new(0,40,0,20)
		ToggleBG.Position = UDim2.new(1,-50,0.5,-10)
		ToggleBG.BackgroundColor3 = Color3.fromRGB(60,60,60)
		ToggleBG.Parent = Frame

		local Circle = Instance.new("Frame")
		Circle.Size = UDim2.new(0,18,0,18)
		Circle.Position = UDim2.new(0,1,0,1)
		Circle.BackgroundColor3 = Color3.new(1,1,1)
		Circle.Parent = ToggleBG

		Instance.new("UICorner", ToggleBG).CornerRadius = UDim.new(1,0)
		Instance.new("UICorner", Circle).CornerRadius = UDim.new(1,0)

		local function Update()
			if toggled then
				ToggleBG.BackgroundColor3 = self.Config.AccentColor
				Circle:TweenPosition(
					UDim2.new(1,-19,0,1),
					Enum.EasingDirection.Out,
					Enum.EasingStyle.Quad,
					0.2,true
				)
			else
				ToggleBG.BackgroundColor3 = Color3.fromRGB(60,60,60)
				Circle:TweenPosition(
					UDim2.new(0,1,0,1),
					Enum.EasingDirection.Out,
					Enum.EasingStyle.Quad,
					0.2,true
				)
			end

			if callback then
				callback(toggled)
			end
		end

		Frame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				toggled = not toggled
				Update()
			end
		end)

		return {
			Set = function(state)
				toggled = state
				Update()
			end,
			Get = function()
				return toggled
			end
		}
	end

	return Folder
end

--// ==============================
--// SLIDER
--// ==============================

function Folder:AddSlider(text, min, max, default, callback)

	min = min or 0
	max = max or 100
	default = default or min

	local value = default

	local Frame = Instance.new("Frame")
	Frame.Size = UDim2.new(1,0,0,50)
	Frame.BackgroundColor3 = self.Config.MainColor
	Frame.Parent = self.Container

	if self.Config.CornerRadius > 0 then
		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0,6)
		c.Parent = Frame
	end

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(1,-10,0,20)
	Label.Position = UDim2.new(0,5,0,0)
	Label.BackgroundTransparency = 1
	Label.Text = text.." : "..value
	Label.TextColor3 = self.Config.TextColor
	Label.Font = Enum.Font.Gotham
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Frame

	local Bar = Instance.new("Frame")
	Bar.Size = UDim2.new(1,-20,0,10)
	Bar.Position = UDim2.new(0,10,0,30)
	Bar.BackgroundColor3 = Color3.fromRGB(60,60,60)
	Bar.Parent = Frame

	if self.Config.CornerRadius > 0 then
		Instance.new("UICorner", Bar).CornerRadius = UDim.new(1,0)
	end

	local Fill = Instance.new("Frame")
	Fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
	Fill.BackgroundColor3 = self.Config.AccentColor
	Fill.Parent = Bar

	if self.Config.CornerRadius > 0 then
		Instance.new("UICorner", Fill).CornerRadius = UDim.new(1,0)
	end

	local dragging = false
	local UIS = game:GetService("UserInputService")

	Bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then

			local pos = math.clamp(
				(input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X,
				0,1
			)

			Fill.Size = UDim2.new(pos,0,1,0)

			value = math.floor(min + ((max-min) * pos))
			Label.Text = text.." : "..value

			if callback then
				callback(value)
			end
		end
	end)

	return {
		Get = function()
			return value
		end,
		Set = function(v)
			v = math.clamp(v, min, max)
			value = v
			Fill.Size = UDim2.new((v-min)/(max-min),0,1,0)
			Label.Text = text.." : "..value
		end
	}
end


--// ==============================
--// DROPDOWN
--// ==============================

function Folder:AddDropdown(text, list, callback)

	list = list or {}
	local selected = nil
	local opened = false

	local Main = Instance.new("Frame")
	Main.Size = UDim2.new(1,0,0,35)
	Main.BackgroundColor3 = self.Config.MainColor
	Main.Parent = self.Container

	if self.Config.CornerRadius > 0 then
		Instance.new("UICorner", Main).CornerRadius = UDim.new(0,6)
	end

	local Button = Instance.new("TextButton")
	Button.Size = UDim2.new(1,0,1,0)
	Button.BackgroundTransparency = 1
	Button.Text = text
	Button.TextColor3 = self.Config.TextColor
	Button.Font = Enum.Font.Gotham
	Button.TextSize = 14
	Button.Parent = Main

	local Container = Instance.new("Frame")
	Container.Size = UDim2.new(1,0,0,0)
	Container.BackgroundColor3 = self.Config.MainColor
	Container.ClipsDescendants = true
	Container.Parent = self.Container

	local UIList = Instance.new("UIListLayout")
	UIList.Parent = Container

	local function Refresh(options)

		Container:ClearAllChildren()
		UIList.Parent = Container

		for _,v in pairs(options) do

			local Option = Instance.new("TextButton")
			Option.Size = UDim2.new(1,0,0,30)
			Option.Text = tostring(v)
			Option.BackgroundColor3 = self.Config.MainColor
			Option.TextColor3 = self.Config.TextColor
			Option.Font = Enum.Font.Gotham
			Option.TextSize = 14
			Option.Parent = Container

			Option.MouseButton1Click:Connect(function()
				selected = v
				Button.Text = text.." : "..v
				opened = false

				Container:TweenSize(
					UDim2.new(1,0,0,0),
					Enum.EasingDirection.Out,
					Enum.EasingStyle.Quad,
					0.2,true
				)

				if callback then
					callback(v)
				end
			end)
		end
	end

	Refresh(list)

	Button.MouseButton1Click:Connect(function()

		opened = not opened

		if opened then
			Container:TweenSize(
				UDim2.new(1,0,0,UIList.AbsoluteContentSize.Y),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.2,true
			)
		else
			Container:TweenSize(
				UDim2.new(1,0,0,0),
				Enum.EasingDirection.Out,
				Enum.EasingStyle.Quad,
				0.2,true
			)
		end
	end)

	return {
		Get = function()
			return selected
		end,
		Refresh = function(newList)
			Refresh(newList)
		end
	}
end


--// ==============================
--// PLAYER DROPDOWN (AUTO)
--// ==============================

function Folder:AddPlayerDropdown(text, callback)

	local Players = game:GetService("Players")

	local function GetPlayers()
		local t = {}
		for _,p in pairs(Players:GetPlayers()) do
			table.insert(t, p.Name)
		end
		return t
	end

	local dropdown = self:AddDropdown(text, GetPlayers(), callback)

	Players.PlayerAdded:Connect(function()
		dropdown.Refresh(GetPlayers())
	end)

	Players.PlayerRemoving:Connect(function()
		dropdown.Refresh(GetPlayers())
	end)

	return dropdown
end

