--// ==============================
--// NOTIFICATION SYSTEM
--// ==============================

function HadesUI:Notify(title, message, duration)

	duration = duration or 3

	local ScreenGui = game.CoreGui:FindFirstChild("HADES_NOTIFICATION_GUI")

	if not ScreenGui then
		ScreenGui = Instance.new("ScreenGui")
		ScreenGui.Name = "HADES_NOTIFICATION_GUI"
		ScreenGui.ResetOnSpawn = false
		ScreenGui.Parent = game.CoreGui
	end

	local Frame = Instance.new("Frame")
	Frame.Size = UDim2.new(0,250,0,80)
	Frame.Position = UDim2.new(1,-260,1,-100)
	Frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
	Frame.Parent = ScreenGui

	Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,8)

	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1,-10,0,30)
	Title.Position = UDim2.new(0,5,0,5)
	Title.BackgroundTransparency = 1
	Title.Text = title
	Title.TextColor3 = Color3.fromRGB(255,255,255)
	Title.Font = Enum.Font.GothamBold
	Title.TextSize = 14
	Title.TextXAlignment = Enum.TextXAlignment.Left
	Title.Parent = Frame

	local Message = Instance.new("TextLabel")
	Message.Size = UDim2.new(1,-10,0,35)
	Message.Position = UDim2.new(0,5,0,35)
	Message.BackgroundTransparency = 1
	Message.TextWrapped = true
	Message.Text = message
	Message.TextColor3 = Color3.fromRGB(200,200,200)
	Message.Font = Enum.Font.Gotham
	Message.TextSize = 13
	Message.TextXAlignment = Enum.TextXAlignment.Left
	Message.Parent = Frame

	Frame.Position = UDim2.new(1,0,1,-100)

	Frame:TweenPosition(
		UDim2.new(1,-260,1,-100),
		Enum.EasingDirection.Out,
		Enum.EasingStyle.Quad,
		0.3,true
	)

	task.delay(duration,function()
		Frame:TweenPosition(
			UDim2.new(1,0,1,-100),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.3,true
		)
		task.wait(0.3)
		Frame:Destroy()
	end)
end

--// ==============================
--// REGISTRO INTERNO DE OBJETOS
--// ==============================

HadesUI._Instances = HadesUI._Instances or {}
HadesUI._MainGui = nil

--// ==============================
--// MEJORAR CREATEWINDOW
--// ==============================

local oldCreateWindow = HadesUI.CreateWindow

function HadesUI:CreateWindow(title)

	-- Eliminar GUI anterior si existe
	if HadesUI._MainGui and HadesUI._MainGui.Parent then
		HadesUI._MainGui:Destroy()
	end

	local Window = oldCreateWindow(self, title)

	HadesUI._MainGui = Window.Main
	table.insert(HadesUI._Instances, Window.Main)

	return Window
end


--// ==============================
--// DESTROY COMPLETO
--// ==============================

function HadesUI:Destroy()

	if HadesUI._MainGui then
		HadesUI._MainGui:Destroy()
		HadesUI._MainGui = nil
	end

	local notif = game.CoreGui:FindFirstChild("HADES_NOTIFICATION_GUI")
	if notif then
		notif:Destroy()
	end

	HadesUI._Instances = {}
end


--// ==============================
--// UPDATE THEME DINÁMICO
--// ==============================

function HadesUI:SetTheme(newTheme)

	for k,v in pairs(newTheme) do
		if self.Config[k] then
			self.Config[k] = v
		end
	end

	if not HadesUI._MainGui then return end

	local function UpdateObjects(obj)
		for _,child in pairs(obj:GetDescendants()) do

			if child:IsA("Frame") then
				if child.BackgroundColor3 ~= Color3.fromRGB(25,25,25) then
					child.BackgroundColor3 = self.Config.MainColor
				end
			end

			if child:IsA("TextLabel") or child:IsA("TextButton") then
				child.TextColor3 = self.Config.TextColor
			end
		end
	end

	UpdateObjects(HadesUI._MainGui)
end


--// ==============================
--// CUADRADO / REDONDO GLOBAL
--// ==============================

function HadesUI:SetSquare()
	self.Config.CornerRadius = 0
	self:SetTheme({})
end

function HadesUI:SetRound(radius)
	radius = radius or 12
	self.Config.CornerRadius = radius

	if not HadesUI._MainGui then return end

	for _,obj in pairs(HadesUI._MainGui:GetDescendants()) do
		if obj:IsA("Frame") then
			local corner = obj:FindFirstChildOfClass("UICorner")
			if corner then
				corner.CornerRadius = UDim.new(0, radius)
			end
		end
	end
end


--// ==============================
--// CAMBIAR FONDO DINÁMICO
--// ==============================

function HadesUI:SetBackground(imageId, transparency)

	if not HadesUI._MainGui then return end

	local bg = HadesUI._MainGui:FindFirstChild("HADES_BG")

	if not bg then
		bg = Instance.new("ImageLabel")
		bg.Name = "HADES_BG"
		bg.Size = UDim2.new(1,0,1,0)
		bg.BackgroundTransparency = 1
		bg.ZIndex = 0
		bg.Parent = HadesUI._MainGui
	end

	bg.Image = "rbxassetid://"..imageId
	bg.ImageTransparency = transparency or 0.3
end

return HadesUI