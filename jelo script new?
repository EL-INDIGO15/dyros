MainTab:AddSwitch("auto equip", function(state)
    _G.AutoEquip = state
    if state then
        -- ANIMACIÓN DE ENTRADA
        MainBg.Visible = true
        Container.Position = UDim2.new(0.5, -275, 0.5, -500)
        TweenService:Create(Container, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0.5, -275, 0.5, -110)}):Play()

        task.spawn(function()
            local total = #pesasCoords
            for i, coord in ipairs(pesasCoords) do
                if not _G.AutoEquip then break end
                local progress = i / total
                -- ACTUALIZACIÓN DE BARRA CON ANIMACIÓN
                TweenService:Create(BarFill, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = UDim2.new(progress, 0, 1, 0)}):Play()
                PercentText.Text = math.floor(progress * 100) .. "% COMPLETADO"
                SubTitle.Text = "Procesando zona: "..i.." de "..total

                local char = player.Character or player.CharacterAdded:Wait()
                char:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(coord + Vector3.new(0, 3, 0))
                task.wait(0.3)

                -- ACTIVAR TODOS LOS PROMPTS
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") and (v.Parent.Position - coord).Magnitude < 12 then
                        fireproximityprompt(v)
                    end
                end

                -- REVIVIR PARA ACTIVAR CORRECTAMENTE
                if i < total and _G.AutoEquip then
                    player.Character:BreakJoints()
                    player.CharacterAdded:Wait()
                    task.wait(0.2)
                end
            end

            -- TELETRANSPORTE FINAL
            if _G.AutoEquip then 
                PercentText.Text = "Cargado"
                SubTitle.Text = "Auto Equip Cargado"
                task.wait(0.8)
                player.Character:WaitForChild("HumanoidRootPart").CFrame = tpIslaFinal
                -- ANIMACIÓN DE SALIDA
                TweenService:Create(Container, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0.5, -275, 0.5, -500)}):Play()
                task.wait(0.4)
                MainBg.Visible = false
            end
        end)
    else
        if MainBg.Visible then
            TweenService:Create(Container, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -275, 0.5, -500)}):Play()
            task.wait(0.3)
            MainBg.Visible = false
        end
    end
end)

MainTab:AddSwitch("auto durabilidad", function(state)
    _G.AutoDurability = state
    if state then
        task.spawn(function()
            local rocas = {}
            for _, o in pairs(workspace:GetDescendants()) do
                if o:IsA("BasePart") and (o.Name:lower():find("roca") or o.Name:lower():find("rock")) then
                    table.insert(rocas, o) 
                    o.Transparency = 1 
                    o.CanCollide = false
                end
            end
            local loop = RunService.Heartbeat:Connect(function()
                if not _G.AutoDurability then loop:Disconnect() return end
                local h = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if h then 
                    for _, r in pairs(rocas) do 
                        r.Anchored = true 
                        r.CFrame = h.CFrame * CFrame.new(0,-8,-2) 
                    end 
                end
            end)
            while _G.AutoDurability do
                local r = ReplicatedStorage:FindFirstChild("RocaDurabilidadHit")
                if r then r:FireServer() end
                task.wait(0.05)
            end
        end)
    end
end)

