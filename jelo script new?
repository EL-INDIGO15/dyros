-- --- LÓGICA DE EJECUCIÓN ---
local function startFarming()
    MainBg.Visible = true
    local total = #pesasCoords
    local ultimaCoord = pesasCoords[total]
    
    -- FASE 1: RECORRIDO CON PANTALLA NEGRA
    for i, coord in ipairs(pesasCoords) do
        if not _G.AutoFarmActive then break end
        
        StatusText.Text = "EQUIPANDO: " .. i .. " / " .. total
        local char = player.Character or player.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart").CFrame = CFrame.new(coord + Vector3.new(0, 3, 0))
        
        task.wait(0.5)
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                local pPos = (v.Parent:IsA("BasePart") and v.Parent.Position) or (v.Parent:IsA("Model") and v.Parent:GetPivot().Position)
                if pPos and (pPos - coord).Magnitude < 15 then
                    fireproximityprompt(v)
                end
            end
        end
    end

    -- FASE 2: LLEGADA AL FINAL Y QUITAR GUI
    if _G.AutoFarmActive then
        MainBg.Visible = false -- Quitamos el blackout
        
        -- Bucle infinito en la última posición
        while _G.AutoFarmActive do
            local char = player.Character or player.CharacterAdded:Wait()
            local hrp = char:FindFirstChild("HumanoidRootPart")
            
            if hrp then
                -- Se mantiene en la última coordenada
                hrp.CFrame = CFrame.new(ultimaCoord + Vector3.new(0, 3, 0))
                
                -- Spam del prompt de la última pesa
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") then
                        local pPos = (v.Parent:IsA("BasePart") and v.Parent.Position) or (v.Parent:IsA("Model") and v.Parent:GetPivot().Position)
                        if pPos and (pPos - ultimaCoord).Magnitude < 15 then
                            fireproximityprompt(v)
                        end
                    end
                end
            end
            task.wait(0.1) -- Velocidad de farmeo constante
        end
    end
end

