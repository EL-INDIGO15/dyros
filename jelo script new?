-- formato abreviado
local function FormatNumber(n)
	if typeof(n) ~= "number" then return tostring(n) end
	
	local suffix = {"","K","M","B","T","Qa","Qi","Sx","Sp","Oc","No","Dc"}
	local i = 1
	
	while n >= 1000 and i < #suffix do
		n = n / 1000
		i = i + 1
	end
	
	return string.format("%.2f", n) .. suffix[i]
end

-- obtener stat segura
local function getLeaderStat(player, statName)
	if not player then return 0 end
	
	local leader = player:FindFirstChild("leaderstats")
	if not leader then
		leader = player:WaitForChild("leaderstats", 3)
	end
	if not leader then return 0 end
	
	local stat = leader:FindFirstChild(statName)
	if stat and (stat:IsA("IntValue") or stat:IsA("NumberValue")) then
		return stat.Value
	end
	
	return 0
end

-- durabilidad desde PrivateStats
local function getDurability(player)
	if not player then return 0 end
	
	local folder = player:FindFirstChild("PrivateStats")
	if not folder then
		folder = player:WaitForChild("PrivateStats", 3)
	end
	if not folder then return 0 end
	
	local dura = folder:FindFirstChild("Durabilidad")
	if dura and (dura:IsA("IntValue") or dura:IsA("NumberValue")) then
		return dura.Value
	end
	
	return 0
end

