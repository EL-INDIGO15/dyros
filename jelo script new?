-- 📌 FORMATO ABREVIADO
local function format(n)
        if n >= 1e12 then return string.format("%.2fT", n/1e12) end
        if n >= 1e9 then return string.format("%.2fB", n/1e9) end
        if n >= 1e6 then return string.format("%.2fM", n/1e6) end
        if n >= 1e3 then return string.format("%.1fK", n/1e3) end
        return tostring(math.floor(n))
end

local startTime = tick()
local fuerzaInicial, renasInicial
local lastFuerza = 0
local lastRenas = 0

-- 🔁 MULTIPLICADOR BASE (cámbialo si quieres 40 ↔ 80 etc)
local baseMult = 60
local multiplier = baseMult

task.spawn(function()
        while true do
                task.wait(1)

                local leaderstats = player:FindFirstChild("leaderstats")
                if not leaderstats then continue end

                local fuerzaValue = leaderstats:FindFirstChild("Fuerza")
                local renasValue = leaderstats:FindFirstChild("Renacimientos")
                if not fuerzaValue or not renasValue then continue end

                local currentFuerza = fuerzaValue.Value
                local currentRenas = renasValue.Value

                if not fuerzaInicial then fuerzaInicial = currentFuerza end
                if not renasInicial then renasInicial = currentRenas end

                local fuerzaGanada = currentFuerza - fuerzaInicial
                local renasGanadas = currentRenas - renasInicial

                local fuerzaGain = math.max(0, currentFuerza - lastFuerza)
                local renaGain = math.max(0, currentRenas - lastRenas)

                -- 🔄 ALTERNA ENTRE BASE Y EL DOBLE
                if multiplier == baseMult then
                        multiplier = baseMult * 2
                else
                        multiplier = baseMult
                end

                local tiempoTotal = math.floor(tick() - startTime)
                tiempoLabel.Text = "⏱ Tiempo: " .. tiempoTotal .. "s"

                -- 💪 FUERZA
                fuerzaActualLabel.Text = "💪 Fuerza: " .. format(currentFuerza)
                fuerzaGanadoLabel.Text = "📈 Ganado: " .. format(fuerzaGanada)

                fuerzaMinLabel.Text = "⚡ minuto → " .. format(fuerzaGain * multiplier)
                fuerzaHoraLabel.Text = "⚡ Hora → " .. format(fuerzaGain * multiplier * 60)
                fuerzaDiaLabel.Text = "⚡ Día → " .. format(fuerzaGain * multiplier * 1440)

                -- 🔄 RENAS
                renaActualLabel.Text = "🔄 Renas: " .. format(currentRenas)
                renaGanadoLabel.Text = "📈 Ganado: " .. format(renasGanadas)

                renaMinLabel.Text = "⚡ minuto → " .. format(renaGain * multiplier)
                renaHoraLabel.Text = "⚡ Hora → " .. format(renaGain * multiplier * 60)
                renaDiaLabel.Text = "⚡ Día → " .. format(renaGain * multiplier * 1440)

                lastFuerza = currentFuerza
                lastRenas = currentRenas
        end
end)

