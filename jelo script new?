-- =====================================================
-- ⚫ ANTI LAG 2 (MAPA NEGRO)
-- =====================================================

local OriginalParts = {}
local OriginalLighting = {}
local FullLagEnabled = false

local function EnableFullBlack()
	if FullLagEnabled then return end
	FullLagEnabled = true

	OriginalLighting.Brightness = Lighting.Brightness
	OriginalLighting.GlobalShadows = Lighting.GlobalShadows

	Lighting.Brightness = 0
	Lighting.GlobalShadows = false

	for _, part in pairs(Workspace:GetDescendants()) do
		if part:IsA("BasePart") then
			OriginalParts[part] = {
				Color = part.Color,
				Material = part.Material
			}
			part.Color = Color3.new(0,0,0)
			part.Material = Enum.Material.SmoothPlastic
		end
	end
end

local function DisableFullBlack()
	if not FullLagEnabled then return end
	FullLagEnabled = false

	for setting, value in pairs(OriginalLighting) do
		Lighting[setting] = value
	end

	for part, props in pairs(OriginalParts) do
		if part and part.Parent then
			part.Color = props.Color
			part.Material = props.Material
		end
	end

	table.clear(OriginalParts)
end

Misc:AddSwitch("Full antilag", function(state)
	if state then
		EnableFullBlack()
	else
		DisableFullBlack()
	end
end):Set(false)


