    end
end)

local MainTab = window:AddTab("AutoFarm")

-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)


-- ================= ULTRA FAST FARM =================

local AutoFarmUltra = false
local AutoEquipBest = false

local player = game.Players.LocalPlayer

-- 🔥 AUTO EQUIP MEJOR SCYTHE
local function equipBestTool()
    local backpack = player:FindFirstChild("Backpack")
    local bestTool = nil

    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                bestTool = tool -- toma la última (normalmente la mejor)
            end
        end
    end

    if bestTool and player.Character then
        player.Character.Humanoid:EquipTool(bestTool)
    end
end

task.spawn(function()
    while true do
        if AutoEquipBest then
            pcall(equipBestTool)
        end
        task.wait(1)
    end
end)

-- 🔥 ULTRA AUTO SWING (SIN DELAY)
task.spawn(function()
    while true do
        if AutoFarmUltra then
            local char = player.Character
            if char then
                for _, tool in pairs(char:GetChildren()) do
                    if tool:IsA("Tool") then
                        
                        local remote = tool:FindFirstChildWhichIsA("RemoteEvent", true)

                        if remote then
                            for i = 1, 10 do -- 🔥 MULTI HIT
                                pcall(function()
                                    remote:FireServer()
                                end)
                            end
                        end

                    end
                end
            end
        end
        task.wait() -- sin delay 🔥
    end
end)

-- 🔥 ANTI DELAY (QUITAR COOLDOWN VISUAL)
task.spawn(function()
    while true do
        if AutoFarmUltra and player.Character then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("NumberValue") and v.Name:lower():find("cooldown") then
                    v.Value = 0
                end
            end
        end
        task.wait(0.1)
    end
end)

