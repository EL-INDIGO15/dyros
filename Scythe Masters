task.spawn(function()
    local i = 1
    while true do
        local c1 = colores[i]
        local c2 = colores[i % #colores + 1]
        for t = 0,1,0.02 do
            options.main_color = c1:Lerp(c2, t)
            task.wait(0.05)
        end
        i = i % #colores + 1
    end
end)

local MainTab = window:AddTab("AutoFarm")

-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)


-- ================= AUTO FARM + REBIRTH REAL =================

local AutoFarm = false
local AutoRebirth3 = false
local AutoRebirth30 = false
local AutoRebirth300 = false

-- AUTO SWING MÁS RÁPIDO
task.spawn(function()
    while true do
        if AutoFarm then
            for _, v in pairs(game.Players.LocalPlayer.Character:GetChildren()) do
                if v:IsA("Tool") then
                    local remote = v:FindFirstChildWhichIsA("RemoteEvent", true)
                    if remote then
                        pcall(function()
                            remote:FireServer()
                        end)
                    end
                end
            end
        end
        task.wait(0.01) -- MÁS RÁPIDO 🔥
    end
end)

-- AUTO REBIRTH REAL (BOTONES)
local function clickRebirth()
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("TextButton") and v.Text == "Rebirth" then
            
            local textLabel = v.Parent:FindFirstChildWhichIsA("TextLabel")
            if textLabel then
                local txt = textLabel.Text:lower()

                if AutoRebirth3 and txt:find("3 rebirth") then
                    v:Activate()
                elseif AutoRebirth30 and txt:find("30 rebirth") then
                    v:Activate()
                elseif AutoRebirth300 and txt:find("300 rebirth") then
                    v:Activate()
                end
            end
        end
    end
end

task.spawn(function()
    while true do
        clickRebirth()
        task.wait(0.3)
    end
end)

