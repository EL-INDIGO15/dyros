task.spawn(function()
    local i = 1
    while true do
        local c1 = colores[i]
        local c2 = colores[i % #colores + 1]
        for t = 0,1,0.02 do
            options.main_color = c1:Lerp(c2, t)
            task.wait(0.05)
        end
        i = i % #colores + 1
    end
end)

local MainTab = window:AddTab("AutoFarm")

-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)


-- ================= AUTO REBIRTH SWITCHES (FIX REAL) =================

local AutoRebirth3 = false
local AutoRebirth30 = false
local AutoRebirth300 = false
local AutoRebirth3k = false

local function clickRebirth()
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("TextButton") then

            local parentText = ""
            if v.Parent and v.Parent:FindFirstChildWhichIsA("TextLabel") then
                parentText = v.Parent:FindFirstChildWhichIsA("TextLabel").Text:lower()
            end

            -- 🔥 detectar botón verde (activo)
            if v.Text == "Rebirth" and v.AutoButtonColor == true then

                -- 🔥 3
                if AutoRebirth3 and parentText:find("3 rebirth") and not parentText:find("30") then
                    pcall(function() v:Activate() end)
                end

                -- 🔥 30
                if AutoRebirth30 and parentText:find("30 rebirth") then
                    pcall(function() v:Activate() end)
                end

                -- 🔥 300
                if AutoRebirth300 and parentText:find("300 rebirth") then
                    pcall(function() v:Activate() end)
                end

                -- 🔥 3K
                if AutoRebirth3k and (parentText:find("3k rebirth") or parentText:find("3000")) then
                    pcall(function() v:Activate() end)
                end

            end
        end
    end
end

task.spawn(function()
    while true do
        if AutoRebirth3 or AutoRebirth30 or AutoRebirth300 or AutoRebirth3k then
            clickRebirth()
        end
        task.wait(0.4)
    end
end)

