-- CARGA DE LIBRERÍA 
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/EL-INDIGO15/dyros/refs/heads/main/libreria"))() 

-- JUGADOR 
local player = game.Players.LocalPlayer 
local displayName = player.DisplayName or player.Name 

-- VENTANA 
local options = {
    main_color = Color3.fromRGB(220, 20, 60),
    min_size = Vector2.new(600, 820),
    can_resize = false,
}

local window = library:AddWindow("HadesHubClanGHTONTOP|Scythe Masters - AutoFarm - Bienvenid@ " .. displayName, options)

-- ANIMACIÓN COLOR 
local colores = {
    Color3.fromRGB(220,20,60), Color3.fromRGB(255,102,102),
    Color3.fromRGB(255,0,0), Color3.fromRGB(255,140,0),
    Color3.fromRGB(255,165,0), Color3.fromRGB(255,215,0),
    Color3.fromRGB(255,255,0)
}

task.spawn(function()
    local i = 1
    while true do
        local c1 = colores[i]
        local c2 = colores[i % #colores + 1]
        for t = 0,1,0.02 do
            options.main_color = c1:Lerp(c2, t)
            task.wait(0.05)
        end
        i = i % #colores + 1
    end
end)

local MainTab = window:AddTab("AutoFarm")

-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)


-- ================= ULTRA FAST FARM v2 =================

local AutoFarmUltra = false
local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

-- 🔥 CACHE DEL TOOL (para no buscar cada frame)
local currentTool = nil

local function updateTool()
    local char = player.Character
    if char then
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Tool") then
                currentTool = v
                return
            end
        end
    end
    currentTool = nil
end

-- actualizar cuando respawneas
player.CharacterAdded:Connect(function()
    task.wait(1)
    updateTool()
end)

task.spawn(function()
    while true do
        updateTool()
        task.wait(1)
    end
end)

-- 🔥 ULTRA SPAM (MUCHO MÁS RÁPIDO)
RunService.RenderStepped:Connect(function()
    if not AutoFarmUltra then return end

    if currentTool and currentTool.Parent == player.Character then
        local remote = currentTool:FindFirstChildWhichIsA("RemoteEvent", true)

        if remote then
            -- 🔥 SPAM MASIVO
            for i = 1, 25 do
                pcall(function()
                    remote:FireServer()
                end)
            end
        end
    end
end)

-- 🔥 EXTRA LOOP (doble velocidad)
task.spawn(function()
    while true do
        if AutoFarmUltra and currentTool then
            local remote = currentTool:FindFirstChildWhichIsA("RemoteEvent", true)

            if remote then
                for i = 1, 15 do
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            end
        end
        task.wait() -- sin delay
    end
end)

-- 🔥 ANTI COOLDOWN
task.spawn(function()
    while true do
        if AutoFarmUltra and player.Character then
            for _, v in pairs(player.Character:GetDescendants()) do
                if v:IsA("NumberValue") and v.Name:lower():find("cooldown") then
                    v.Value = 0
                end
            end
        end
        task.wait(0.05)
    end
end)

-- ================= SWITCH =================
MainTab:AddSwitch("🔥 Ultra Fast Farm v2", function(v)
    AutoFarmUltra = v
end)