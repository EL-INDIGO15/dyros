-- ================= AUTO REBIRTH UI METHOD (CELULAR FIX) =================

local function clickRebirthButton()
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("TextButton") or v:IsA("ImageButton") then
            local text = (v.Text or ""):lower()
            local name = v.Name:lower()

            if text:find("rebirth") or name:find("rebirth") then
                pcall(function()
                    v:Activate()
                end)
            end
        end
    end
end

task.spawn(function()
    while true do
        if AutoRebirth3Enabled or AutoRebirth30Enabled or AutoRebirth300Enabled or AutoRebirth3kEnabled then
            clickRebirthButton()
        end
        task.wait(0.5)
    end
end)