local MainTab = window:AddTab("AutoFarm")

-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)

-- ================= AUTO REBIRTH (FIX TOTAL) =================

local AutoRebirth3Enabled = false
local AutoRebirth30Enabled = false
local AutoRebirth300Enabled = false
local AutoRebirth3kEnabled = false

local rebirthRemote = nil

local function findRebirthRemote()
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local n = obj.Name:lower()
            if n:find("rebirth") or n:find("reset") or n:find("mega") then
                rebirthRemote = obj

                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "Rebirth Detectado",
                    Text = obj.Name,
                    Duration = 4
                })
                return
            end
        end
    end
end

task.spawn(function()
    task.wait(2)
    findRebirthRemote()
end)

MainTab:AddSwitch("Auto 3", function(v) AutoRebirth3Enabled = v end)
MainTab:AddSwitch("Auto 30", function(v) AutoRebirth30Enabled = v end)
MainTab:AddSwitch("Auto 300", function(v) AutoRebirth300Enabled = v end)
MainTab:AddSwitch("Auto 3k", function(v) AutoRebirth3kEnabled = v end)

task.spawn(function()
    while true do
        if rebirthRemote then
            pcall(function()

                local list = {}
                if AutoRebirth3Enabled then table.insert(list, 3) end
                if AutoRebirth30Enabled then table.insert(list, 30) end
                if AutoRebirth300Enabled then table.insert(list, 300) end
                if AutoRebirth3kEnabled then table.insert(list, 3000) end

                for _, amount in ipairs(list) do

                    if rebirthRemote:IsA("RemoteEvent") then
                        rebirthRemote:FireServer(amount)
                        rebirthRemote:FireServer("rebirth", amount)
                        rebirthRemote:FireServer("rebirth")
                    end

                    if rebirthRemote:IsA("RemoteFunction") then
                        rebirthRemote:InvokeServer(amount)
                    end

                end
            end)
        end
        task.wait(0.1)
    end
end)


