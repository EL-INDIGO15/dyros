task.spawn(function()
    local i = 1
    while true do
        local c1 = colores[i]
        local c2 = colores[i % #colores + 1]
        for t = 0,1,0.02 do
            options.main_color = c1:Lerp(c2, t)
            task.wait(0.05)
        end
        i = i % #colores + 1
    end
end)

local MainTab = window:AddTab("AutoFarm")

-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)


-- ================= AUTO REBIRTH REAL (BOTONES ESPECÍFICOS) =================

local AutoRebirth3Enabled = false
local AutoRebirth30Enabled = false
local AutoRebirth300Enabled = false
local AutoRebirth3kEnabled = false

local function clickRebirthButtons()

    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("TextButton") then

            local text = (v.Text or ""):lower()

            -- 🔥 3
            if AutoRebirth3Enabled and (text:find("3") and not text:find("30") and not text:find("300")) then
                pcall(function() v:Activate() end)
            end

            -- 🔥 30
            if AutoRebirth30Enabled and text:find("30") and not text:find("300") then
                pcall(function() v:Activate() end)
            end

            -- 🔥 300
            if AutoRebirth300Enabled and text:find("300") and not text:find("3000") then
                pcall(function() v:Activate() end)
            end

            -- 🔥 3000 / 3k
            if AutoRebirth3kEnabled and (text:find("3000") or text:find("3k")) then
                pcall(function() v:Activate() end)
            end

        end
    end

end

task.spawn(function()
    while true do
        if AutoRebirth3Enabled or AutoRebirth30Enabled or AutoRebirth300Enabled or AutoRebirth3kEnabled then
            clickRebirthButtons()
        end
        task.wait(0.3)
    end
end)

-- SWITCHES
MainTab:AddSwitch("Auto 3 Rebirth", function(v) AutoRebirth3Enabled = v end)
MainTab:AddSwitch("Auto 30 Rebirth", function(v) AutoRebirth30Enabled = v end)
MainTab:AddSwitch("Auto 300 Rebirth", function(v) AutoRebirth300Enabled = v end)
MainTab:AddSwitch("Auto 3k Rebirth", function(v) AutoRebirth3kEnabled = v end)