local rebirthRemote = nil   -- ← Aquí guardaremos el remote que encuentre automáticamente

-- ================= FUNCIÓN PARA BUSCAR EL REMOTE DE REBIRTH AUTOMÁTICAMENTE =================
local function findRebirthRemote()
    -- 1. Primero probamos el remote que usaba en Muscle Masters (el que ya te funcionaba antes)
    local possible = {
        ReplicatedStorage:FindFirstChild("RemotesEvent") and ReplicatedStorage.RemotesEvent:FindFirstChild("RebirthEvent"),
        ReplicatedStorage:FindFirstChild("RemotesEvent") and ReplicatedStorage.RemotesEvent:FindFirstChild("Rebirth"),
        ReplicatedStorage:FindFirstChild("RebirthEvent"),
        ReplicatedStorage:FindFirstChild("Rebirth"),
        ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Rebirth"),
    }
    
    for _, remote in ipairs(possible) do
        if remote and remote:IsA("RemoteEvent") then
            rebirthRemote = remote
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "✅ Rebirth Remote Encontrado",
                Text = "Usando: " .. remote.Name .. " (en " .. (remote.Parent and remote.Parent.Name or "ReplicatedStorage") .. ")",
                Duration = 6
            })
            return
        end
    end

    -- 2. Búsqueda profunda automática en todo ReplicatedStorage (si no encontró el anterior)
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") and (obj.Name:lower():find("rebirth") or obj.Name:lower():find("mega") or obj.Name:lower():find("reset")) then
            rebirthRemote = obj
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "✅ Rebirth Remote Encontrado (Búsqueda profunda)",
                Text = "Nombre: " .. obj.Name .. "\nRuta: " .. obj:GetFullName(),
                Duration = 8
            })
            return
        end
    end

    -- Si no encontró nada
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "⚠️ Rebirth Remote NO encontrado",
        Text = "No se detectó ningún remote con 'rebirth'. Prueba activar los switches de rebirth de todos modos o dime qué ves en la consola.",
        Duration = 8
    })
end

-- Ejecutamos la búsqueda automática al cargar el script
task.spawn(findRebirthRemote)

-- ================= AUTO SWING (versión que ya te funcionaba) =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") and tool.Handle:FindFirstChild("Script") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    updateScythe()
    if swingThread then task.cancel(swingThread) end
    
    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe.Handle.Script:FindFirstChild("RemoteEvent")
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing (Strength Farm)", function(state)
    AutoSwingEnabled = state
    if state then
        startAutoSwing()
    else
        if swingThread then task.cancel(swingThread) end
    end
end)

-- Reinicio automático del swing después de renacer
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1.5)
    updateScythe()
    if AutoSwingEnabled then
        startAutoSwing()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "AutoFarm", Text = "✅ Auto Swing reiniciado después del rebirth", Duration = 4
        })
    end
    -- También re-buscar el remote de rebirth por si acaso
    task.wait(2)
    if not rebirthRemote then findRebirthRemote() end
end)

