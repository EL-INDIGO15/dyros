-- VARIABLES
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = player

local AutoSwingEnabled = false
local swingThread = nil
local currentScythe = nil

-- ================= AUTO SWING =================
local function updateScythe()
    if LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
                currentScythe = tool
                return
            end
        end
    end
    currentScythe = nil
end

local function startAutoSwing()
    if swingThread then task.cancel(swingThread) end

    swingThread = task.spawn(function()
        while AutoSwingEnabled do
            if currentScythe and currentScythe.Parent == LocalPlayer.Character then
                local remote = currentScythe:FindFirstChildWhichIsA("RemoteEvent", true)
                if remote then
                    pcall(function()
                        remote:FireServer()
                    end)
                end
            else
                updateScythe()
            end
            game:GetService("RunService").Heartbeat:Wait()
        end
    end)
end

MainTab:AddSwitch("Auto Swing", function(state)
    AutoSwingEnabled = state
    if state then startAutoSwing() end
end)

-- ================= PLAYER FARM v2 =================

local PlayerFarmTab = window:AddTab("Player Farm")

local AutoPlayerFarm = false
local player = game.Players.LocalPlayer

-- 🔥 LISTA DE JUGADORES
local function getPlayersList()
    local list = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            table.insert(list, v)
        end
    end
    return list
end

-- 🔥 TELEPORT DETRÁS
local function teleportBehind(target)
    local char = game.Players.LocalPlayer.Character
    if not char then return end

    local myHRP = char:FindFirstChild("HumanoidRootPart")
    local targetHRP = target.Character and target.Character:FindFirstChild("HumanoidRootPart")

    if myHRP and targetHRP then
        local behindPosition = targetHRP.Position - (targetHRP.CFrame.LookVector * 4)

        myHRP.CFrame = CFrame.new(behindPosition, targetHRP.Position)
    end
end

-- 🔥 ATACAR
local function attack()
    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
    if tool then
        local remote = tool:FindFirstChildWhichIsA("RemoteEvent", true)
        if remote then
            for i = 1, 8 do
                pcall(function()
                    remote:FireServer()
                end)
            end
        end
    end
end

-- 🔥 LOOP PRINCIPAL
task.spawn(function()
    while true do
        if AutoPlayerFarm then
            
            local playersList = getPlayersList()

            for _, target in ipairs(playersList) do
                if not AutoPlayerFarm then break end

                local startTime = tick()

                while tick() - startTime < 1 do -- ⏱️ 1 segundo
                    if not AutoPlayerFarm then break end

                    if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        pcall(function()
                            teleportBehind(target)
                            attack()
                        end)
                    end

                    task.wait() -- sin delay
                end
            end

        end
        task.wait(0.1)
    end
end)

-- ================= SWITCH =================
PlayerFarmTab:AddSwitch("💀 Auto Player Farm (1s)", function(v)
    AutoPlayerFarm = v
end)

-- ================= TARGET PLAYER FARM =================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local TargetTab = window:AddTab("Target Player")

local following = false
local followTarget = nil

-- 🔥 TELEPORT DETRÁS REAL
local function followPlayer(targetPlayer)
    local myChar = LocalPlayer.Character
    local targetChar = targetPlayer.Character

    if not (myChar and targetChar) then return end

    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")

    if myHRP and targetHRP then
        local behindPos = targetHRP.Position - (targetHRP.CFrame.LookVector * 4)
        myHRP.CFrame = CFrame.new(behindPos, targetHRP.Position)
    end
end

-- 🔥 ATAQUE
local function attack()
    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if tool then
        local remote = tool:FindFirstChildWhichIsA("RemoteEvent", true)
        if remote then
            for i = 1, 8 do
                pcall(function()
                    remote:FireServer()
                end)
            end
        end
    end
end

