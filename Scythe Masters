-- ================= AUTO REBIRTH OP (VERSIÓN MEJORADA) =================

local AutoRebirth3Enabled = false
local AutoRebirth30Enabled = false
local AutoRebirth300Enabled = false
local AutoRebirth3kEnabled = false

local rebirthRemote = nil

-- 🔍 BUSCADOR MEJORADO (RemoteEvent + RemoteFunction)
local function findRebirthRemote()
    for _, obj in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
        if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then
            local name = obj.Name:lower()
            if name:find("rebirth") or name:find("reset") or name:find("mega") then
                rebirthRemote = obj

                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "✅ Rebirth Detectado",
                    Text = "Usando: " .. obj.Name,
                    Duration = 5
                })

                return
            end
        end
    end

    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "❌ No encontrado",
        Text = "No se detectó el remote de rebirth",
        Duration = 5
    })
end

-- Ejecutar búsqueda
task.spawn(findRebirthRemote)

-- ================= SWITCHES =================
MainTab:AddSwitch("Auto 3 Rebirth", function(state)
    AutoRebirth3Enabled = state
end)

MainTab:AddSwitch("Auto 30 Rebirth", function(state)
    AutoRebirth30Enabled = state
end)

MainTab:AddSwitch("Auto 300 Rebirth", function(state)
    AutoRebirth300Enabled = state
end)

MainTab:AddSwitch("Auto 3k Rebirth", function(state)
    AutoRebirth3kEnabled = state
end)

-- ================= LOOP INTELIGENTE =================
task.spawn(function()
    while true do
        if rebirthRemote then
            pcall(function()

                local amounts = {}

                if AutoRebirth3Enabled then table.insert(amounts, 3) end
                if AutoRebirth30Enabled then table.insert(amounts, 30) end
                if AutoRebirth300Enabled then table.insert(amounts, 300) end
                if AutoRebirth3kEnabled then table.insert(amounts, 3000) end

                for _, amount in ipairs(amounts) do

                    -- 🔥 Intento 1: RemoteEvent normal
                    if rebirthRemote:IsA("RemoteEvent") then
                        rebirthRemote:FireServer(amount)
                    end

                    -- 🔥 Intento 2: RemoteFunction
                    if rebirthRemote:IsA("RemoteFunction") then
                        rebirthRemote:InvokeServer(amount)
                    end

                    -- 🔥 Intento 3: con string
                    if rebirthRemote:IsA("RemoteEvent") then
                        rebirthRemote:FireServer("rebirth", amount)
                    end

                    -- 🔥 Intento 4: solo string
                    if rebirthRemote:IsA("RemoteEvent") then
                        rebirthRemote:FireServer("rebirth")
                    end

                end
            end)
        end
        task.wait(0.1)
    end
end)

-- 🔘 BOTÓN PARA RE-BUSCAR
MainTab:AddButton("🔍 Buscar Rebirth Otra Vez", function()
    rebirthRemote = nil
    findRebirthRemote()
end)
