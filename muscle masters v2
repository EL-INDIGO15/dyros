-- 🔢 FORMATO
local function FormatNumber(n)
    if typeof(n) ~= "number" then return tostring(n) end
    local suffix = {"","K","M","B","T"}
    local i = 1
    while n >= 1000 and i < #suffix do
        n /= 1000
        i += 1
    end
    return string.format("%.2f", n) .. suffix[i]
end

-- 🔍 FIND STAT FIXED
local function findStat(plr, names)
    if not plr then return "N/A" end

    local leader = plr:FindFirstChild("leaderstats")
    if leader then
        for _, stat in pairs(leader:GetChildren()) do
            for _, name in pairs(names) do
                if stat.Name:lower():find(name:lower()) then
                    return stat.Value
                end
            end
        end
    end

    for _, v in pairs(plr:GetDescendants()) do
        if v:IsA("NumberValue") or v:IsA("IntValue") then
            for _, name in pairs(names) do
                if v.Name:lower():find(name:lower()) then
                    return v.Value
                end
            end
        end
    end

    return "N/A"
end

