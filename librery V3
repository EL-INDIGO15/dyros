-- Internal Memory Helper
local function HandleMemory(window, key, defaultValue)

    if not window.Config.SmartMemory then
        return defaultValue
    end

    if HadesUI._Memory[key] ~= nil then
        return HadesUI._Memory[key]
    end

    HadesUI._Memory[key] = defaultValue
    return defaultValue
end

