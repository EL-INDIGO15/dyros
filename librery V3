function HadesUI:AddKeybind(TabPage, text, defaultKey, callback)

    local window = HadesUI._Windows[#HadesUI._Windows]
    local config = window.Config

    local memoryKey = text .. "_KEYBIND"
    defaultKey = HandleMemory(window, memoryKey, defaultKey or Enum.KeyCode.RightControl)

    local CurrentKey = defaultKey
    local waiting = false

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1,-10,0,35)
    Button.Position = UDim2.new(0,5,0,0)
    Button.Text = text .. " : " .. CurrentKey.Name
    Button.Font = Enum.Font.Gotham
    Button.TextSize = 14
    Button.TextColor3 = config.TextColor
    Button.BackgroundColor3 = config.MainColor
    Button.Parent = TabPage

    Instance.new("UICorner", Button).CornerRadius = UDim.new(0,config.CornerRadius)

    Button.MouseButton1Click:Connect(function()
        waiting = true
        Button.Text = text .. " : ..."
    end)

    UIS.InputBegan:Connect(function(input, gpe)
        if gpe then return end

        if waiting then
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                CurrentKey = input.KeyCode
                Button.Text = text .. " : " .. CurrentKey.Name
                waiting = false

                if window.Config.SmartMemory then
                    HadesUI._Memory[memoryKey] = CurrentKey
                end
            end
        else
            if input.KeyCode == CurrentKey then
                if callback then
                    callback()
                end
            end
        end
    end)

    return {
        Get = function()
            return CurrentKey
        end
    }
end

