function HadesUI:EnableRainbow(speed)

    speed = speed or 0.1

    task.spawn(function()
        while task.wait(speed) do
            local hue = tick() % 5 / 5
            local color = Color3.fromHSV(hue,1,1)

            for _, window in pairs(HadesUI._Windows) do
                window.Config.AccentColor = color
            end
        end
    end)
end

