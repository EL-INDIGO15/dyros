--// =============================

function HadesUI:AddDropdown(TabPage, text, options, default, callback, searchable)

    local window = HadesUI._Windows[#HadesUI._Windows]
    local config = window.Config

    options = options or {}

    local memoryKey = text .. "_DROPDOWN"
    default = HandleMemory(window, memoryKey, default or options[1])

    local Selected = default

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1,-10,0,35)
    Frame.Position = UDim2.new(0,5,0,0)
    Frame.BackgroundColor3 = config.MainColor
    Frame.Parent = TabPage

    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,config.CornerRadius)

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1,0,1,0)
    Button.Text = text .. " : " .. tostring(Selected)
    Button.Font = Enum.Font.Gotham
    Button.TextSize = 14
    Button.TextColor3 = config.TextColor
    Button.BackgroundTransparency = 1
    Button.Parent = Frame

    local DropFrame = Instance.new("Frame")
    DropFrame.Size = UDim2.new(1,-10,0,0)
    DropFrame.Position = UDim2.new(0,5,0,40)
    DropFrame.BackgroundColor3 = config.MainColor
    DropFrame.Visible = false
    DropFrame.Parent = TabPage

    Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0,config.CornerRadius)

    local Layout = Instance.new("UIListLayout", DropFrame)
    Layout.Padding = UDim.new(0,3)

    local SearchBox

    if searchable then
        SearchBox = Instance.new("TextBox")
        SearchBox.Size = UDim2.new(1,0,0,30)
        SearchBox.PlaceholderText = "Search..."
        SearchBox.Text = ""
        SearchBox.Font = Enum.Font.Gotham
        SearchBox.TextSize = 13
        SearchBox.TextColor3 = config.TextColor
        SearchBox.BackgroundColor3 = Color3.fromRGB(40,40,40)
        SearchBox.Parent = DropFrame

        Instance.new("UICorner", SearchBox).CornerRadius = UDim.new(0,6)
    end

    local function Refresh(filter)

        for _, child in pairs(DropFrame:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in pairs(options) do

            if filter and not string.find(string.lower(option), string.lower(filter)) then
                continue
            end

            local OptionBtn = Instance.new("TextButton")
            OptionBtn.Size = UDim2.new(1,0,0,30)
            OptionBtn.Text = option
            OptionBtn.Font = Enum.Font.Gotham
            OptionBtn.TextSize = 13
            OptionBtn.TextColor3 = config.TextColor
            OptionBtn.BackgroundColor3 = Color3.fromRGB(45,45,45)
            OptionBtn.Parent = DropFrame

            Instance.new("UICorner", OptionBtn).CornerRadius = UDim.new(0,6)

            OptionBtn.MouseButton1Click:Connect(function()
                Selected = option
                Button.Text = text .. " : " .. Selected
                DropFrame.Visible = false
                DropFrame.Size = UDim2.new(1,-10,0,0)

                if window.Config.SmartMemory then
                    HadesUI._Memory[memoryKey] = Selected
                end

                if callback then
                    callback(Selected)
                end
            end)
        end

        DropFrame.Size = UDim2.new(1,-10,0,#DropFrame:GetChildren()*33)
    end

    Button.MouseButton1Click:Connect(function()
        DropFrame.Visible = not DropFrame.Visible
        if DropFrame.Visible then
            Refresh()
        else
            DropFrame.Size = UDim2.new(1,-10,0,0)
        end
    end)

    if SearchBox then
        SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
            Refresh(SearchBox.Text)
        end)
    end

    if callback then
        callback(Selected)
    end

    return {
        Get = function()
            return Selected
        end,
        Set = function(val)
            Selected = val
            Button.Text = text .. " : " .. Selected
        end
    }
end

