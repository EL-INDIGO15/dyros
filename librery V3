-- Create Tab System
function HadesUI:_CreateTabSystem(Window)

    local config = Window.Config
    local Main = Window.Main
    local Container = Window.Container

    local TabHolder = Instance.new("Frame")
    TabHolder.Name = "HADES_TAB_HOLDER"
    TabHolder.BackgroundTransparency = 1
    TabHolder.Parent = Container

    local PageHolder = Instance.new("Frame")
    PageHolder.Name = "HADES_PAGE_HOLDER"
    PageHolder.BackgroundTransparency = 1
    PageHolder.Parent = Container

    if config.TabStyle == "VerticalTab" then
        
        TabHolder.Size = UDim2.new(0,150,1,0)
        TabHolder.Position = UDim2.new(0,0,0,0)

        PageHolder.Size = UDim2.new(1,-150,1,0)
        PageHolder.Position = UDim2.new(0,150,0,0)

    else -- Default Horizontal
        
        TabHolder.Size = UDim2.new(1,0,0,40)
        TabHolder.Position = UDim2.new(0,0,0,0)

        PageHolder.Size = UDim2.new(1,0,1,-40)
        PageHolder.Position = UDim2.new(0,0,0,40)

        config.TabStyle = "HorizontalTab"
    end

    local TabLayout = Instance.new("UIListLayout")
    TabLayout.FillDirection = config.TabStyle == "VerticalTab" and Enum.FillDirection.Vertical or Enum.FillDirection.Horizontal
    TabLayout.Parent = TabHolder

    Window.TabHolder = TabHolder
    Window.PageHolder = PageHolder
end

-- Add Tab
function HadesUI:AddTab(Window, name)

    if not Window.TabHolder then
        self:_CreateTabSystem(Window)
    end

    local config = Window.Config

    local TabButton = Instance.new("TextButton")
    TabButton.Text = name
    TabButton.Font = Enum.Font.Gotham
    TabButton.TextSize = 14
    TabButton.TextColor3 = config.TextColor
    TabButton.BackgroundColor3 = config.MainColor
    TabButton.AutoButtonColor = false

    if config.TabStyle == "VerticalTab" then
        TabButton.Size = UDim2.new(1,0,0,40)
    else
        TabButton.Size = UDim2.new(0,120,1,0)
    end

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0,config.CornerRadius)
    corner.Parent = TabButton

    TabButton.Parent = Window.TabHolder

    local Page = Instance.new("Frame")
    Page.Name = name .. "_PAGE"
    Page.Size = UDim2.new(1,0,1,0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.Parent = Window.PageHolder

    local UIList = Instance.new("UIListLayout")
    UIList.Padding = UDim.new(0,6)
    UIList.Parent = Page

    Window.Tabs[name] = {
        Button = TabButton,
        Page = Page
    }

    -- First tab auto visible
    if #Window.PageHolder:GetChildren() == 2 then
        Page.Visible = true
        TabButton.BackgroundColor3 = config.AccentColor
    end

    TabButton.MouseButton1Click:Connect(function()

        for tabName,tabData in pairs(Window.Tabs) do
            tabData.Page.Visible = false
            tabData.Button.BackgroundColor3 = config.MainColor
        end

        Page.Visible = true
        TabButton.BackgroundColor3 = config.AccentColor

    end)

    return Page
end

