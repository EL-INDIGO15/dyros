function HadesUI:AddToggle(TabPage, text, default, callback)

    local window = HadesUI._Windows[#HadesUI._Windows]
    local config = window.Config

    local memoryKey = text .. "_TOGGLE"
    default = HandleMemory(window, memoryKey, default or false)

    local State = default

    local Toggle = Instance.new("TextButton")
    Toggle.Size = UDim2.new(1,-10,0,35)
    Toggle.Position = UDim2.new(0,5,0,0)
    Toggle.Text = text
    Toggle.Font = Enum.Font.Gotham
    Toggle.TextSize = 14
    Toggle.TextColor3 = config.TextColor
    Toggle.BackgroundColor3 = State and config.AccentColor or config.MainColor
    Toggle.Parent = TabPage

    Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0,config.CornerRadius)

    Toggle.MouseButton1Click:Connect(function()

        State = not State
        Toggle.BackgroundColor3 = State and config.AccentColor or config.MainColor

        if window.Config.SmartMemory then
            HadesUI._Memory[memoryKey] = State
        end

        if callback then
            callback(State)
        end
    end)

    if callback then
        callback(State)
    end

    return {
        Get = function()
            return State
        end,
        Set = function(val)
            State = val
            Toggle.BackgroundColor3 = State and config.AccentColor or config.MainColor
            if window.Config.SmartMemory then
                HadesUI._Memory[memoryKey] = State
            end
        end
    }
end

