local rng = Random.new()

-- =========================
-- AUTO FARM
-- =========================
local AutoFarm = false
local threads = {}

local function stopThreads()
    for _, t in ipairs(threads) do
        if t then task.cancel(t) end
    end
    table.clear(threads)
end

local function GetPrompts(folder, positions)
    local prompts = {}
    for _, obj in ipairs(folder:GetDescendants()) do
        if obj:IsA("BasePart") then
            for _, pos in ipairs(positions) do
                if (obj.Position - pos).Magnitude < 0.1 then
                    local prompt = obj:FindFirstChild("ProximityPromptMachine")
                    if prompt then
                        table.insert(prompts, prompt)
                    end
                end
            end
        end
    end
    return prompts
end

local function RunFarm()
    local folder = workspace:WaitForChild("MachinesFolder")
    local remote = ReplicatedStorage.RemotesEvent.MachineActiveEvent

    local positions = rebirths.Value < 10 and {
        Vector3.new(-120,5,-56),
        Vector3.new(-94,5,-35)
    } or {
        Vector3.new(2747,7,105),
        Vector3.new(2747,7,126)
    }

    local prompts = GetPrompts(folder, positions)

    table.insert(threads, task.spawn(function()
        while AutoFarm do
            local p = prompts[rng:NextInteger(1,#prompts)]
            if p then fireproximityprompt(p) end
            task.wait(0.01)
        end
    end))

    table.insert(threads, task.spawn(function()
        while AutoFarm do
            remote:FireServer()
            task.wait(0.01)
        end
    end))
end

farmTab:AddSwitch("Auto Farm", function(state)
    AutoFarm = state
    stopThreads()
    if state then RunFarm() end
end)

