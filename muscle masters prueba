-- =========================
-- PLAYER TAB
-- =========================
local selectedPlayer = nil

local function getPlayers()
    local list = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer then
            table.insert(list, p.Name)
        end
    end
    return list
end

playerTab:AddDropdown("Select Player", getPlayers(), function(value)
    selectedPlayer = value
end)

-- KILL PLAYER
local KillPlayer = false

playerTab:AddSwitch("Kill Player", function(state)
    KillPlayer = state

    if state then
        task.spawn(function()
            while KillPlayer do
                local target = Players:FindFirstChild(selectedPlayer)
                if target and target.Character and localPlayer.Character then
                    local myHRP = localPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")

                    if myHRP and targetHRP then
                        myHRP.CFrame = targetHRP.CFrame
                        local tool = localPlayer.Backpack:FindFirstChild("Punch")
                        if tool then
                            tool.Parent = localPlayer.Character
                            tool:Activate()
                        end
                    end
                end
                task.wait(0.01)
            end
        end)
    end
end)

-- KILL ALL
local KillAll = false

playerTab:AddSwitch("Kill All", function(state)
    KillAll = state

    if state then
        task.spawn(function()
            while KillAll do
                for _, plr in pairs(Players:GetPlayers()) do
                    if plr ~= localPlayer and plr.Character then
                        local myHRP = localPlayer.Character:FindFirstChild("HumanoidRootPart")
                        local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")

                        if myHRP and targetHRP then
                            myHRP.CFrame = targetHRP.CFrame
                            local tool = localPlayer.Backpack:FindFirstChild("Punch")
                            if tool then
                                tool.Parent = localPlayer.Character
                                tool:Activate()
                            end
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
end)

