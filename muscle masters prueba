    Color3.fromRGB(255, 255, 0),   -- Amarillo puro
}

-- ANIMACIÓN DE COLOR (cambia suavemente entre todos los colores)
task.spawn(function()
    local indice = 1
    while true do
        local colorActual = colores[indice]
        local colorSiguiente = colores[indice % #colores + 1]

        -- Transición suave entre color actual y siguiente (50 pasos)
        for i = 0, 50 do
            local alpha = i / 50
            options.main_color = colorActual:Lerp(colorSiguiente, alpha)
            task.wait(0.05)  -- Velocidad de la animación (ajusta si quieres más rápido/lento)
        end

        indice = indice % #colores + 1  -- Pasa al siguiente color
    end
end) 

local AutoFarm = window:AddTab("Main+") 

-- ================= VARIABLES =================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

local AutoFarmEnabled = false
local AutoGlitchEnabled = false
local AutoRebirthEnabled = false

local farmThreads = {}
local glitchThreads = {}

local rng = Random.new()
local rng2 = Random.new()

-- ================= FUNCIONES BASE =================
local function stopThreads(tbl)
    for _, t in ipairs(tbl) do
        if t then task.cancel(t) end
    end
    table.clear(tbl)
end

local function getPrompts(folder, positions)
    local prompts = {}
    for _, obj in ipairs(folder:GetDescendants()) do
        if obj:IsA("BasePart") then
            for _, pos in ipairs(positions) do
                if (obj.Position - pos).Magnitude < 0.01 then
                    local p = obj:FindFirstChild("ProximityPromptMachine")
                    if p then
                        table.insert(prompts, p)
                    end
                end
            end
        end
    end
    return prompts
end

-- ================= AUTO FARM =================
local function startAutoFarm()
    local rebirths = player.leaderstats.Rebirths.Value

    local positions = (rebirths < 10) and {
        Vector3.new(-120.77, 5.02, -56.94),
        Vector3.new(-94.25, 5.02, -35.08)
    } or {
        Vector3.new(2747.89, 7.65, 105.53),
        Vector3.new(2747.89, 7.65, 126.65),
        Vector3.new(2743.69, 11.66, 233.43),
        Vector3.new(2743.69, 11.66, 258.49)
    }

    local folder = workspace:WaitForChild("MachinesFolder")
    local remote = ReplicatedStorage.RemotesEvent.MachineActiveEvent

    local prompts = getPrompts(folder, positions)

    table.insert(farmThreads, task.spawn(function()
        while AutoFarmEnabled do
            local p = prompts[rng:NextInteger(1, #prompts)]
            if p and p.Enabled then fireproximityprompt(p) end
            task.wait(0.0001)
        end
    end))

    table.insert(farmThreads, task.spawn(function()
        while AutoFarmEnabled do
            remote:FireServer()
            task.wait(0.0001)
        end
    end))
end

AutoFarm:AddSwitch("Auto Farm", function(state)
    AutoFarmEnabled = state
    stopThreads(farmThreads)

    if state then
        startAutoFarm()
    end
end)

